# ============================================================================
# MVT Events - Configurações de Ambiente
# ============================================================================
# 
# Este arquivo contém as variáveis de ambiente para configuração da aplicação.
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env (não versionado no git)
# 2. Preencha os valores reais das variáveis
# 3. Carregue com: source .env && ./gradlew bootRun
#
# Opcional: credenciais de produção só na sua máquina — use um arquivo ignorado pelo git,
# por exemplo .env.producao ou .env.prod (veja .gitignore), e suba o BE assim:
#   set -a && source .env.producao && export SPRING_FLYWAY_ENABLED=false && set +a && ./gradlew bootRun
#
# ============================================================================

# ----------------------------------------------------------------------------
# MODO IUGU (Controla integração com gateway de pagamentos)
# ----------------------------------------------------------------------------
# Valores possíveis:
#   - dry-run    : Mock local (não chama Iugu, retorna dados fake)
#   - sandbox    : Iugu Sandbox (teste com API key test_xxx)
#   - production : Iugu Production (real com API key live_xxx)
#
# Recomendação: Use dry-run para desenvolvimento local
# ----------------------------------------------------------------------------
IUGU_MODE=dry-run

# ----------------------------------------------------------------------------
# CREDENCIAIS IUGU
# ----------------------------------------------------------------------------
# API Key do Iugu:
#   - Modo dry-run   : Qualquer valor (não é usado)
#   - Modo sandbox   : Obtenha em https://iugu.com (começa com test_)
#   - Modo production: Obtenha em https://iugu.com (começa com live_)
# ----------------------------------------------------------------------------
IUGU_API_KEY=test_PLACEHOLDER_REPLACE_WITH_TEST_API_KEY
IUGU_ACCOUNT_ID=PLACEHOLDER_MASTER_ACCOUNT_ID
IUGU_WEBHOOK_TOKEN=PLACEHOLDER_REPLACE_WITH_WEBHOOK_TOKEN

# ----------------------------------------------------------------------------
# BANCO DE DADOS
# ----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5435/mvt-events
SPRING_DATASOURCE_USERNAME=mvt
SPRING_DATASOURCE_PASSWORD=mvtpass

# --- Opcional: BE local apontando para PostgreSQL de produção (debug mapa / API) ---
# Atenção: dados reais; use usuário READ-ONLY se o provedor permitir; rede: VPN, IP na allowlist
# do RDS/Cloud SQL ou túnel SSH (ex.: ssh -L 5435:prod-db.internal:5432 bastion).
# Desligue Flyway para não aplicar migrações no banco de produção ao subir o Spring:
#   export SPRING_FLYWAY_ENABLED=false
# URL típica com SSL (ajuste host, porta, database):
#   SPRING_DATASOURCE_URL=jdbc:postgresql://SEU_HOST:5432/mvt-events?sslmode=require
#   SPRING_DATASOURCE_USERNAME=...
#   SPRING_DATASOURCE_PASSWORD=...
#
# Backfill actual_route (corte pickup→último destino, igual ao complete), ex. corrida 80:
#   source .env.local && ./scripts/billing-retrim-actual-route.sh 80

# ----------------------------------------------------------------------------
# SEGURANÇA JWT
# ----------------------------------------------------------------------------
# JWT Configuration
# IMPORTANTE: Gere um valor aleatório forte em produção!
# Exemplo: openssl rand -base64 64
JWT_SECRET=your-very-long-secret-key-here-at-least-256-bits
JWT_EXPIRATION=18000

# ----------------------------------------------------------------------------
# SERVIDOR
# ----------------------------------------------------------------------------
# Server Configuration
SERVER_PORT=8080

# ----------------------------------------------------------------------------
# WEB PUSH (Notificações Push)
# ----------------------------------------------------------------------------
# VAPID Keys para notificações push
# Gere com: node generate-vapid-keys-correct.js
VAPID_PUBLIC_KEY=BN8ym6-oByG6GoAEC939-qcmE9ej3Dt8ovEXVY_example_key
VAPID_PRIVATE_KEY=example_private_key_replace_with_real_one
VAPID_SUBJECT=mailto:admin@mvt-events.com

# ----------------------------------------------------------------------------
# PROVIDERS DE PAGAMENTO ANTIGOS (Stripe, MercadoPago, PayPal)
# ----------------------------------------------------------------------------
# ⚠️ NOTA: O sistema agora usa IUGU como provider principal
# As configurações abaixo são mantidas para compatibilidade legada
# ----------------------------------------------------------------------------

# Payment Provider (STRIPE, MERCADOPAGO, or PAYPAL)
PAYMENT_PROVIDER=STRIPE

# Stripe Configuration
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# MercadoPago Configuration (optional)
MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token
MERCADOPAGO_WEBHOOK_SECRET=your_mercadopago_webhook_secret

# PayPal Configuration (optional)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENVIRONMENT=sandbox

# Payment URLs
PAYMENT_RETURN_URL=http://localhost:3000/payment/success
PAYMENT_CANCEL_URL=http://localhost:3000/payment/cancel
PAYMENT_WEBHOOK_URL=http://localhost:8080/api/payments/webhook

# ----------------------------------------------------------------------------
# PIX OUT (transferência plataforma → courier via chave PIX)
# ----------------------------------------------------------------------------
# Valores: log (stub padrão) | stark (Stark Bank) | inter (Banco Inter)
PIX_OUT_PROVIDER=log

# Stark Bank (quando PIX_OUT_PROVIDER=stark)
STARKBANK_ENV=sandbox
STARKBANK_PROJECT_ID=
STARKBANK_PRIVATE_KEY=

# Banco Inter (quando PIX_OUT_PROVIDER=inter)
# Credenciais da integração criada em contadigital.inter.co → Integrar → Nova Integração
INTER_ENV=sandbox
INTER_CLIENT_ID=
INTER_CLIENT_SECRET=
# Caminho absoluto pro .p12/.pfx emitido pelo Inter
# (se Inter entregou .crt+.key, converta: openssl pkcs12 -export -in inter.crt -inkey inter.key -out inter.p12 -passout pass:SENHA)
INTER_PKCS12_PATH=
INTER_PKCS12_PASSWORD=
# Só preencha se sua empresa tem múltiplas contas PJ no Inter
INTER_ACCOUNT=
